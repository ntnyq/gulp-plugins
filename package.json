{
  "name": "gulp-plugins",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm -r run dev",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint",
    "prepare": "husky",
    "release": "run-s release:check build release:publish",
    "release:check": "run-s format:check lint typecheck test",
    "release:publish": "changeset publish",
    "release:version": "changeset version",
    "test": "vitest",
    "typecheck": "tsgo --noEmit"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@types/through2": "catalog:",
    "@types/vinyl": "catalog:",
    "@typescript/native-preview": "^7.0.0-dev.20260329.1",
    "husky": "^9.1.7",
    "nano-staged": "^0.9.0",
    "npm-run-all2": "^8.0.4",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "through2": "catalog:",
    "tsdown": "^0.21.7",
    "vinyl": "catalog:",
    "vitest": "^4.1.2"
  },
  "nano-staged": {
    "*.{js,ts,mjs,tsx}": "oxlint --fix",
    "*": "oxfmt --no-error-on-unmatched-pattern"
  },
  "packageManager": "pnpm@10.33.0"
}
