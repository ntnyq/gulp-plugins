{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": [
    "eslint",
    "import",
    "jsdoc",
    "node",
    "promise",
    "oxc",
    "typescript",
    "unicorn"
  ],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "pedantic": "warn",
    "perf": "warn",
    "style": "warn",
    "restriction": "warn",
    "nursery": "warn"
  },
  "ignorePatterns": ["**/dist/**", "**/node_modules/**", "**/fixtures/**"],
  "rules": {
    "capitalized-comments": "off",
    "no-ternary": "off",
    "no-nested-ternary": "off",
    "no-param-reassign": "off",
    "prefer-destructuring": "off",
    "require-await": "off",
    "sort-imports": "off",
    "sort-keys": "off",
    "import/max-dependencies": "off",
    "import/exports-last": "off",
    "import/group-exports": "off",
    "import/no-named-export": "off",
    "import/prefer-default-export": "off",
    "import/no-nodejs-modules": "off",
    "import/no-default-export": "off",
    "import/no-unassigned-import": "off",
    "import/no-relative-parent-imports": "off",
    "jsdoc/require-param": "off",
    "jsdoc/require-param-type": "off",
    "jsdoc/require-returns-type": "off",
    "oxc/no-async-await": "off",
    "oxc/no-barrel-file": "off",
    "oxc/no-optional-chaining": "off",
    "oxc/no-rest-spread-properties": "off",
    "promise/always-return": "off",
    "promise/avoid-new": "off",
    "promise/catch-or-return": "off",
    "promise/prefer-await-to-then": "off",
    "promise/prefer-await-to-callbacks": "off",
    "typescript/explicit-module-boundary-types": "off",
    "typescript/explicit-function-return-type": "off",
    "unicorn/filename-case": "off",
    "unicorn/no-array-reverse": "off",
    "unicorn/no-process-exit": "off",
    "unicorn/no-array-for-each": "off",
    "unicorn/no-null": "off",
    "unicorn/no-nested-ternary": "off",
    "unicorn/prefer-global-this": "off",
    "unicorn/prefer-module": "off",
    "unicorn/prefer-top-level-await": "off",
    "func-style": ["warn", "declaration", { "allowArrowFunctions": true }],
    "id-length": [
      "warn",
      {
        "min": 2,
        "max": 30,
        "properties": "never",
        "exceptions": [
          // Compare
          "a",
          "b",
          // Loop
          "i",
          "m",
          "n",
          "s",
          "v",
          "x",
          "y",
          // Generic types
          "T",
          "F",
          // Unused vars
          "_",
          "$"
        ]
      }
    ],
    "max-lines-per-function": [
      "warn",
      {
        "max": 200,
        "skipComments": true,
        "skipBlankLines": true
      }
    ],
    "max-statements": [
      "warn",
      {
        "max": 50
      }
    ],
    "no-duplicate-imports": [
      "warn",
      { "allowSeparateTypeImports": true, "includeExports": true }
    ],
    "no-magic-numbers": [
      "warn",
      {
        "ignore": [0, 1, -1],
        "ignoreArrayIndexes": true,
        "enforceConst": true,
        "detectObjects": false
      }
    ]
  },
  "overrides": [
    {
      "files": ["scripts/**/*.{js,ts}"],
      "rules": {
        "import/no-nodejs-modules": "off",
        "import/prefer-default-export": "off",
        "import/no-named-export": "off"
      }
    },
    {
      "files": ["**/*.config.{ts,mjs}"],
      "rules": {
        "new-cap": "off",
        "import/no-default-export": "off"
      }
    },
    {
      "files": ["*.d.ts"],
      "rules": {
        // to extend existing modules, import/export must not appear in declaration files at top level
        "import/unambiguous": "off",
        "typescript/ban-types": "off",
        "typescript/no-empty-object-type": "off",
        "typescript/no-explicit-any": "off",
        // we need `export {}` to convert a file to a module
        "unicorn/require-module-specifiers": "off"
      }
    },
    {
      "files": ["*.{spec,test}.{js,ts,tsx}", "*.{spec,test}-d.{ts,tsx}"],
      "plugins": ["vitest"],
      "rules": {
        "id-length": "off",
        "max-classes-per-file": "off",
        "max-lines-per-function": "off",
        "max-lines": "off",
        "max-statements": "off",
        "no-empty-function": "off",
        "no-magic-numbers": "off",
        "no-undefined": "off",
        "import/no-nodejs-modules": "off",
        "typescript/ban-ts-comment": "off",
        "typescript/no-non-null-assertion": "off",
        "typescript/prefer-ts-expect-error": "off",
        "typescript/require-array-sort-compare": "off",
        "vitest/no-importing-vitest-globals": "off"
      }
    }
  ]
}
